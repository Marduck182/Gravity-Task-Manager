{
  "name": "gravity-task-manager",
  "version": "1.0.0",
  "description": "Premium Task Manager for Windows",
  "main": "dist/main/main.js",
  "author": "AlanJ",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"node scripts/watch-electron.js\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main && electron-builder --win",
    "compile": "npm run build:renderer && npm run build:main"
  },
  "dependencies": {
    "lucide-react": "^0.439.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.gravity.taskmanager",
    "productName": "Gravity Task Manager",
    "win": {
      "target": "portable"
    },
    "directories": {
      "output": "dist-package"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ]
  }
}
